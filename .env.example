# ===============================
# Dbs Environment Configuration
# ===============================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===============================
# DATABASE CONFIGURATION
# ===============================
# Your Cloudflare Worker proxy URL (hides Supabase infrastructure)
VITE_DB_ENDPOINT=https://your-proxy.workers.dev
VITE_DB_PUBLIC_KEY=your_public_token_here

# Legacy names for backwards compatibility
VITE_SUPABASE_URL=https://your-proxy.workers.dev
VITE_SUPABASE_ANON_KEY=your_public_token_here

# ===============================
# SECURITY CONFIGURATION
# ===============================
# Cloudflare Turnstile Site Key (get from Cloudflare Dashboard)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Cloudflare Turnstile verification
# Set to 'false' to ENABLE security verification (RECOMMENDED for production)
# Only set to 'true' for LOCAL development
VITE_DISABLE_TURNSTILE=false

# ===============================
# FEATURES CONFIGURATION
# ===============================
# Disable Supabase Realtime (WebSocket connections)
# Set to 'true' if using Cloudflare Worker proxy without WebSocket support
VITE_DISABLE_REALTIME=false
